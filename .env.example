# GHL Marketplace App Credentials
NEXT_PUBLIC_GHL_CLIENT_ID=""
GHL_CLIENT_SECRET=""
# Required for Company-level installs (/oauth/installedLocations).
# This is the Marketplace App ID (24 hex chars), not the OAuth client ID.
GHL_MARKETPLACE_APP_ID=""
GHL_APP_VERSION_ID="2021-07-28"

# Supabase Credentials (for DB and Queues)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Upstash Redis (OPTIONAL)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Security Keys
# Must be exactly 32 bytes (64 hex characters) for AES-256
TOKEN_ENCRYPTION_KEY=""

# Secret used to secure the cron job endpoint from unauthorized triggers
CRON_SECRET=""

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional explicit marketplace listing URL used by landing/support CTAs.
# Example: https://marketplace.gohighlevel.com/integration/<your-app-id>
NEXT_PUBLIC_GHL_MARKETPLACE_INSTALL_URL=""
